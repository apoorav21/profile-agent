# ==============================
# OPENAI
# ==============================
OPENAI_API_KEY=sk-proj-...
OPENAI_BRAIN_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini

# ==============================
# GITHUB
# ==============================
# Create at: github.com/settings/tokens/new
# Scopes: repo, read:user
GITHUB_TOKEN=ghp_...
GITHUB_USERNAME=your_github_username

# ==============================
# LINKEDIN
# ==============================
# Create app at: developer.linkedin.com
# Enable: "Share on LinkedIn" product
# Set redirect URI to: http://127.0.0.1:8080/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://127.0.0.1:8080/callback
# Populated automatically by: python auth/linkedin_oauth.py
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ACCESS_TOKEN_EXPIRY=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_PERSON_ID=

# ==============================
# TWITTER / X (optional)
# ==============================
# Create app at: developer.twitter.com
# Set permissions: Read and Write
# Generate Access Token in Keys and Tokens tab (OAuth 1.0a)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ==============================
# BEHAVIOR CONTROLS
# ==============================
ENABLE_LINKEDIN_POSTING=true
ENABLE_TWITTER_POSTING=false
ENABLE_RESUME_UPDATE=true
ENABLE_GITHUB_README_UPDATE=true
# Minimum days before re-posting about the same repo
MIN_DAYS_BETWEEN_REPO_POSTS=30
